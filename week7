# lions/views.py

from django.shortcuts import render, redirect, get_object_or_404

from .models import Lion



# 1. 목록 조회 및 데이터 생성 처리 (/lions/)

def index(request):

    if request.method == 'POST':

        # POST 요청: 새로운 아기사자 생성

        name = request.POST.get('name')

        track = request.POST.get('track')

        if name:

            Lion.objects.create(name=name, track=track)

        return redirect('lions:index')

        

    else:

        # GET 요청: 목록 조회 및 검색/필터

        keyword = request.GET.get('keyword', '')

        if keyword:

            lions = Lion.objects.filter(name__icontains=keyword)

        else:

            lions = Lion.objects.all()

            

        return render(request, 'lions/index.html', {'lions': lions, 'keyword': keyword})



# 2. 생성 Form 화면 제공 (/lions/new/)

def new(request):

    return render(request, 'lions/new.html')



# 3. 상세 정보 조회 및 데이터 수정 처리 (/lions/<id>/)

def detail(request, pk):

    lion = get_object_or_404(Lion, pk=pk)

    

    if request.method == 'POST':

        # POST 요청: 해당 아기사자 정보 수정

        lion.name = request.POST.get('name')

        lion.track = request.POST.get('track')

        if lion.name:

            lion.save()

        return redirect('lions:detail', pk=lion.pk)

        

    else:

        # GET 요청: 특정 아기사자 정보 조회

        return render(request, 'lions/detail.html', {'lion': lion})



# 4. 수정 Form 화면 제공 (/lions/<id>/edit/)

def edit(request, pk):

    lion = get_object_or_404(Lion, pk=pk)

    return render(request, 'lions/edit.html', {'lion': lion})



# 5. 삭제 처리 (/lions/<id>/delete/)

def delete(request, pk):

    if request.method == 'POST':

        lion = get_object_or_404(Lion, pk=pk)

        lion.delete()

    return redirect('lions:index')

