# lions/models.py

from django.db import models



class Lion(models.Model):

    name = models.CharField(max_length=50)

    track = models.CharField(max_length=50)

    created_at = models.DateTimeField(auto_now_add=True) # 데이터 생성 시간 자동 저장



    def __str__(self):

        return self.name

