    path('<int:pk>/', views.detail, name='detail'),          # /lions/1/ 접속 시 (상세)

    path('<int:pk>/edit/', views.edit, name='edit'),         # /lions/1/edit/ 접속 시 (수정)

    path('<int:pk>/delete/', views.delete, name='delete'),   # 삭제 처리 (POST 요청)

]



# lions/views.py

from django.shortcuts import render, redirect, get_object_or_404

from .models import Lion



# 1. 목록 조회 및 검색 (/lions/)

def index(request):

    keyword = request.GET.get('keyword', '')

    if keyword:

        # 이름에 키워드가 포함된 데이터만 필터링

        lions = Lion.objects.filter(name__icontains=keyword)

    else:

        # 키워드가 없으면 전체 데이터 조회

        lions = Lion.objects.all()

    

    context = {

        'lions': lions,

        'keyword': keyword,

    }

    return render(request, 'lions/index.html', context)



# 2. 상세 조회 (/lions/1/)

def detail(request, pk):

    lion = get_object_or_404(Lion, pk=pk)

    return render(request, 'lions/detail.html', {'lion': lion})



# 3. 데이터 생성 (/lions/new/)

def new(request):

    if request.method == 'POST':

        name = request.POST.get('name')

        track = request.POST.get('track')

        

        if name: # 이름은 필수 입력값이므로 체크

            Lion.objects.create(name=name, track=track)

            return redirect('lions:index') # 등록 완료 시 목록으로 리다이렉트

            

    return render(request, 'lions/new.html')



# 4. 데이터 수정 (/lions/1/edit/)

def edit(request, pk):

    lion = get_object_or_404(Lion, pk=pk)

    

    if request.method == 'POST':

        lion.name = request.POST.get('name')

        lion.track = request.POST.get('track')

        

        if lion.name:

            lion.save() # 변경사항 저장

            return redirect('lions:detail', pk=lion.pk) # 수정 후 상세 페이지로 리다이렉트

            

    return render(request, 'lions/edit.html', {'lion': lion})



# 5. 데이터 삭제 (POST 요청 전용)

def delete(request, pk):

    lion = get_object_or_404(Lion, pk=pk)

    if request.method == 'POST':

        lion.delete()

        return redirect('lions:index')

    # GET 요청 등으로 잘못 접근 시 상세페이지로 돌려보냄

    return redirect('lions:detail', pk=lion.pk)



