# lions/models.py

from django.db import models



class Lion(models.Model):

    name = models.CharField(max_length=50)  # 이름 (필수값은 HTML form과 뷰에서 제어)

    track = models.CharField(max_length=50, blank=True)  # 트랙 (선택적 입력 가능)



    def __str__(self):

        return self.name



# lions/urls.py

from django.urls import path

from . import views



app_name = 'lions'



urlpatterns = [

    path('', views.index, name='index'),                     # /lions/ 접속 시 (목록 및 검색)

